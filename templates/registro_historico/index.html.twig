{% extends 'base.html.twig' %}

{% block title %}Registros históricos{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="mb-4">
        <h1 class="h3 mb-0">Registros históricos</h1>
        <p class="text-muted mb-0">
            Histórico geral de interações e anotações
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Data</th>
                            <th>Projeto</th>
                            <th>Título</th>
                            <th>Tipo</th>
                            <th class="text-center">Visível p/ cliente</th>
                        </tr>
                    </thead>
                    <tbody>

                    {% for registro in registros %}
                        <tr>
                            <td class="ps-3 text-nowrap">
                                {{ registro.dataRegistro|date('d/m/Y H:i') }}
                            </td>

                            <td>
                                {{ registro.projeto.titulo }}
                            </td>

                            <td>
                                {{ registro.titulo ?: '—' }}
                            </td>

                            <td>
                                {% set tipos = {
                                    'anotacao': 'Anotação',
                                    'reuniao': 'Reunião',
                                    'ligacao': 'Ligação',
                                    'email': 'E-mail',
                                    'documento': 'Documento'
                                } %}

                                <span class="badge bg-secondary">
                                    {{ tipos[registro.tipoRegistro] ?? 'Anotação' }}
                                </span>
                            </td>

                            <td class="text-center">
                                {% if registro.visivelParaCliente %}
                                    <span class="badge bg-success">Sim</span>
                                {% else %}
                                    <span class="badge bg-light text-dark">Não</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Nenhum registro encontrado
                            </td>
                        </tr>
                    {% endfor %}

                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>
{% endblock %}
