{% extends 'base.html.twig' %}

{% block title %}Cliente{% endblock %}

{% block body %}
    <h1>Cliente</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cliente.id }}</td>
            </tr>
            <tr>
                <th>Tipo</th>
                <td>{{ cliente.tipo }}</td>
            </tr>
            <tr>
                <th>Nome</th>
                <td>{{ cliente.nome }}</td>
            </tr>
            <tr>
                <th>ApelidoFantasia</th>
                <td>{{ cliente.apelidoFantasia }}</td>
            </tr>
            <tr>
                <th>Documento</th>
                <td>{{ cliente.documento }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ cliente.email }}</td>
            </tr>
            <tr>
                <th>TelefonePrincipal</th>
                <td>{{ cliente.telefonePrincipal }}</td>
            </tr>
            <tr>
                <th>TelefoneSecundario</th>
                <td>{{ cliente.telefoneSecundario }}</td>
            </tr>
            <tr>
                <th>Observacoes</th>
                <td>{{ cliente.observacoes }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ cliente.status ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_cliente_index') }}">back to list</a>

    <a href="{{ path('app_cliente_edit', {'id': cliente.id}) }}">edit</a>

    {{ include('cliente/_delete_form.html.twig') }}
{% endblock %}
