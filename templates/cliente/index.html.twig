{% extends 'base.html.twig' %}

{% block title %}Clientes{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Clientes</h1>

        <a href="{{ path('app_cliente_new') }}" class="btn btn-primary">
            + Novo cliente
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Tipo</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                {% for cliente in clientes %}
                    <tr>
                        <td>
                            <strong>{{ cliente.nome }}</strong>
                        </td>

                        <td>
                            {% if cliente.tipo == 'pessoa_fisica' %}
                                Pessoa Física
                            {% else %}
                                Pessoa Jurídica
                            {% endif %}
                        </td>

                        <td>
                            {% if cliente.status %}
                                <span class="badge bg-success">Ativo</span>
                            {% else %}
                                <span class="badge bg-secondary">Inativo</span>
                            {% endif %}
                        </td>

                        <td class="text-end">
                            <a href="{{ path('app_cliente_show', {'id': cliente.id}) }}"
                               class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>

                            <a href="{{ path('app_cliente_edit', {'id': cliente.id}) }}"
                               class="btn btn-sm btn-outline-secondary">
                                Editar
                            </a>

                            {% if cliente.status %}
                                <form method="post"
                                      action="{{ path('app_cliente_inativar', {'id': cliente.id}) }}"
                                      class="d-inline"
                                      onsubmit="return confirm('Tem certeza que deseja inativar este cliente?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Inativar
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            Nenhum cliente cadastrado
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
