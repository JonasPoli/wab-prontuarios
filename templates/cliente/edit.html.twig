{% extends 'base.html.twig' %}

{% block title %}Editar cliente{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="mb-4">
        <h1 class="h3 mb-0">Editar cliente</h1>
        <p class="text-muted mb-0">
            Atualize os dados do cliente
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            {{ form_start(form) }}

            


            <h5 class="mb-3">Dados principais</h5>

            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(form.tipo) }}
                    {{ form_widget(form.tipo, { attr: { class: 'form-select' } }) }}
                    {{ form_errors(form.tipo) }}
                </div>

                <div class="col-md-8 mb-3">
                    {{ form_label(form.nome) }}
                    {{ form_widget(form.nome, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.nome) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.apelidoFantasia) }}
                    {{ form_widget(form.apelidoFantasia, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.apelidoFantasia) }}
                </div>

                <div class="col-md-6 mb-3">
                    {{ form_label(form.documento) }}
                    {{ form_widget(form.documento, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.documento) }}
                </div>
            </div>

            <hr>

           




            <h5 class="mb-3">Contato</h5>

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="col-md-3 mb-3">
                    {{ form_label(form.telefonePrincipal) }}
                    {{ form_widget(form.telefonePrincipal, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.telefonePrincipal) }}
                </div>

                <div class="col-md-3 mb-3">
                    {{ form_label(form.telefoneSecundario) }}
                    {{ form_widget(form.telefoneSecundario, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.telefoneSecundario) }}
                </div>
            </div>

            <hr>

            




            
            <h5 class="mb-3">Observações</h5>

            <div class="mb-3">
                {{ form_label(form.observacoes) }}
                {{ form_widget(form.observacoes, { attr: { class: 'form-control', rows: 4 } }) }}
                {{ form_errors(form.observacoes) }}
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_cliente_index') }}" class="btn btn-outline-secondary">
                    Voltar
                </a>

                <button class="btn btn-primary">
                    Salvar alterações
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </div>

</div>
{% endblock %}
