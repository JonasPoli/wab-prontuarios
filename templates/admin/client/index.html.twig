{% extends 'admin/admin-template.html.twig' %}

{% block title %}Clientes{% endblock %}

{% block content %}
    <style>
        .page-header {
            margin-bottom: 1.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            margin-bottom: 0;
        }

        .listing-card {
            border: 0;
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: 0 0.35rem 1.2rem rgba(0, 0, 0, 0.06);
        }

        .listing-card .card-body {
            padding: 1.5rem;
        }

        .listing-table {
            margin-bottom: 0;
            vertical-align: middle;
        }

        .listing-table thead th {
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #6c757d;
            background: #f8f9fa !important;
            border-bottom: 1px solid #e9ecef;
            white-space: nowrap;
            padding-top: .95rem;
            padding-bottom: .95rem;
        }

        .listing-table tbody td {
            padding-top: 1rem;
            padding-bottom: 1rem;
            border-color: #f1f3f5;
        }

        .client-name {
            font-weight: 700;
            color: #212529;
            margin-bottom: .2rem;
        }

        .client-subname {
            color: #6c757d;
            font-size: .9rem;
        }

        .logo-box {
            min-height: 64px;
            display: flex;
            align-items: center;
            justify-content: center;
            {# background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: .75rem; #}
            padding: .5rem;
        }

        .logo-box img {
            max-height: 52px;
            max-width: 100px;
        }

        .empty-muted {
            color: #adb5bd;
            font-style: italic;
            font-size: .9rem;
        }

        .contact-stack {
            line-height: 1.35;
        }

        .contact-main {
            font-weight: 600;
            color: #212529;
        }

        .contact-secondary {
            color: #6c757d;
            font-size: .9rem;
        }

        .actions-cell {
            min-width: 230px;
        }

        .actions-wrap {
            display: flex;
            gap: .5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .actions-wrap .btn {
            border-radius: .7rem;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 page-header">
        <div>
            <h1 class="mb-1">Clientes</h1>
            <p class="page-subtitle">Cadastro e gerenciamento de clientes</p>
        </div>

        <div class="text-end">
            <a href="{{ path('app_admin_client_new') }}"
               class="btn btn-primary d-inline-flex align-items-center gap-2 px-3 py-2"
               type="button">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 640 640"
                    width="15"
                    height="15"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path d="M352 128C352 110.3 337.7 96 320 96C302.3 96 288 110.3 288 128L288 288L128 288C110.3 288 96 302.3 96 320C96 337.7 110.3 352 128 352L288 352L288 512C288 529.7 302.3 544 320 544C337.7 544 352 529.7 352 512L352 352L512 352C529.7 352 544 337.7 544 320C544 302.3 529.7 288 512 288L352 288L352 128z"/>
                </svg>
                Novo Cliente
            </a>
        </div>
    </div>

    <div class="card listing-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table listing-table display" id="myTable">
                    <thead class="fw-semibold">
                        <tr class="align-middle">
                            <th>Cliente</th>
                            <th class="text-center">Logo</th>
                            <th class="text-center">E-mail</th>
                            <th class="text-center">Telefone</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for client in clients %}
                            <tr class="align-middle">
                                <td>
                                    <div class="client-name">{{ client.name }}</div>
                                    <div class="client-subname">
                                        {{ client.fantasyName ?: 'Sem nome fantasia' }}
                                    </div>
                                </td>

                                <td class="text-center">
                                    <div class="logo-box">
                                        {% if client.logoFilename %}
                                            <img src="{{ asset('uploads/logoFile/' ~ client.logoFilename) }}" alt="{{ client.name }}">
                                        {% else %}
                                            <div class="empty-muted">Sem logo</div>
                                        {% endif %}
                                    </div>
                                </td>

                                <td class="text-center">
                                    {% if client.mail %}
                                        <div class="contact-main">{{ client.mail }}</div>
                                    {% else %}
                                        <div class="empty-muted">Não informado</div>
                                    {% endif %}
                                </td>

                                <td class="text-center">
                                    <div class="contact-stack">
                                        <div class="contact-secondary">{{ client.phone1 ?: '—' }}</div>
                                        <div class="contact-main">{{ client.phone2 ?: '—' }}</div>
                                    </div>
                                </td>

                                <td class="text-center actions-cell">
                                    <div class="actions-wrap">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary"
                                                onclick="location.href='{{ path('app_admin_client_show', {'id': client.id}) }}'">
                                            Ver
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                onclick="location.href='{{ path('app_admin_client_edit', {'id': client.id}) }}'">
                                            Editar
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-success"
                                                onclick="location.href='{{ path('app_admin_conversation_index', {'clientId': client.id}) }}'">
                                            💬 Chat
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}