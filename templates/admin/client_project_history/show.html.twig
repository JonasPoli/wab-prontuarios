{% extends 'admin/admin-template.html.twig' %}

{% block title %}ClientProjectHistory{% endblock %}

{% block content %}

    <h1 class="h3 mb-0">{{ client_project_history.id }}</h1>
            <p class="text-muted mb-0">
                Visualização do registro histórico do projeto
            </p>
    <div class="d-flex justify-content-end gap-2 mb-3">
            <a href="{{ path('app_admin_client_project_history_index') }}" class="btn btn-outline-secondary">
                Voltar
            </a>

            <a href="{{ path('app_admin_client_project_history_edit', {'id': client_project_history.id}) }}" class="btn btn-outline-primary">
                Editar
            </a>
                {{ include('admin/client_project_history/_delete_form.html.twig') }}
        
    </div>

    <div class="card shadow-sm card-body">

    <table class="table">
        <tbody>
            <h5 class="mb-3">Registro Histórico</h5>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ client_project_history.id }}</td>
            </tr> 
            <tr>
                <td>
                    {{ client_project_history.occurredAt ? client_project_history.occurredAt|date('Y-m-d H:i:s') : '' }}
                </td>
            </tr>
            <tr>
                <th>Resumo</th>
                <td>{{ client_project_history.summary }}</td>
            </tr>
            <tr>
                <th>Audio</th>
                <td>
                    {% if client_project_history.audioFilename %}
                        <audio controls>
                            <source src="{{ asset('uploads/audioFile/' ~ client_project_history.audioFilename) }}" type="audio/mpeg">
                            Seu navegador não suporta o elemento de áudio.
                        </audio>
                    {% else %}
                        <p>Nenhum arquivo de áudio disponível.</p>
                    {% endif %}
                </td>
            </tr>

        </tbody>
    </table>

{% endblock %}
