{% extends 'admin/admin-template.html.twig' %}

{% block title %}Projetos{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-2">

    <h1>Cadastro de Projetos</h1>


    <div class="text-end">

        <a href="{{ path('app_admin_client_project_new') }}" 
            class="btn btn-primary mb-2 d-inline-flex align-items-center gap-2" 
            type="button">

        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 640 640"
            width="15"
            height="15"
            fill="currentColor"
            aria-hidden="true"
        >
        
            <path d="M352 128C352 110.3 337.7 96 320 96C302.3 96 288 110.3 288 128L288 288L128 288C110.3 288 96 302.3 96 320C96 337.7 110.3 352 128 352L288 352L288 512C288 529.7 302.3 544 320 544C337.7 544 352 529.7 352 512L352 352L512 352C529.7 352 544 337.7 544 320C544 302.3 529.7 288 512 288L352 288L352 128z"/>
        </svg>
        Novo Projeto
        </a>
    
    </div>
</div>



<table class="table border mb-0"  id="myTable">
  <thead class="fw-semibold text-nowrap">
            <tr class="align-middle">
                <th class="bg-body-secondary">Título</th>
                <th class="bg-body-secondary">Cliente</th>
                {# <th>Status</th> #}
                <th class="bg-body-secondary">Início previsto</th>
                <th class="bg-body-secondary text-center">Ações</th>
            </tr>

        </thead>
        <tbody>
        {% for client_project in client_projects %}
            <tr>
                <td {{ client_project.title|length > 50 ? 'title="' ~ client_project.title ~ '"' : '' }}>
                    {{ client_project.title|length > 50 ? client_project.title|slice(0, 50) ~ '...' : client_project.title }}
                    <br>
                    <small class="text-muted">Anexos: {{ client_project.clientProjectAttacheds|length }}</small>
                </td>
                <td>{{ client_project.client.name }}</td>
               
                {# <td>{{ client_project.status }}</td> #}
                <td>{{ client_project.dateStart ? client_project.dateStart|date('Y-m-d') : '' }}</td>

                    <td class="text-end">

                                
                        <button type="button" class="btn btn-sm btn-outline-info me-2" onclick="location.href='{{ path('app_admin_client_project_attachment_add', {'id': client_project.id})}}'">
                                + Anexo
                        </button>
                                
                        <button type="button" class="btn btn-sm btn-outline-primary me-2" onclick="location.href='{{ path('app_admin_client_project_show', {'id': client_project.id}) }}'">
                                Ver
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary"onclick="location.href='{{ path('app_admin_client_project_edit', {'id': client_project.id}) }}'">
                                Editar
                        </button>                            
                    </td>  
            </tr>
        {# {% else %}
            <tr>
                <td colspan="10">Nenhum registro encontrado</td>
            </tr> #}
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
