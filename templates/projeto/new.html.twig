{% extends 'base.html.twig' %}

{% block title %}Novo projeto{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ================= CABEÇALHO ================= #}
    <div class="mb-4">
        <h1 class="h3 mb-0">Novo projeto</h1>
        <p class="text-muted mb-0">
            Preencha os dados abaixo para cadastrar um novo projeto
        </p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            {{ form_start(form) }}

            {# ================= DADOS PRINCIPAIS ================= #}
            <h5 class="mb-3">Dados principais</h5>

            <div class="row">
                <div class="col-md-8 mb-3">
                    {{ form_label(form.titulo) }}
                    {{ form_widget(form.titulo, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.titulo) }}
                </div>

                <div class="col-md-4 mb-3">
                    {{ form_label(form.cliente) }}
                    {{ form_widget(form.cliente, { attr: { class: 'form-select' } }) }}
                    {{ form_errors(form.cliente) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(form.status) }}
                    {{ form_widget(form.status, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.status) }}
                </div>
            </div>

            <hr>

            {# ================= DESCRIÇÃO ================= #}
            <h5 class="mb-3">Descrição</h5>

            <div class="mb-3">
    {{ form_label(form.descricaoResumida) }}
    {{ form_widget(form.descricaoResumida, {
        attr: { class: 'form-control', rows: 2 }
    }) }}
    {{ form_errors(form.descricaoResumida) }}
</div>

<div class="mb-3">
    {{ form_label(form.descricaoDetalhada) }}
    {{ form_widget(form.descricaoDetalhada, {
        attr: { class: 'form-control', rows: 4 }
    }) }}
    {{ form_errors(form.descricaoDetalhada) }}
</div>

            <hr>

            {# ================= DATAS ================= #}
            <h5 class="mb-3">Prazos</h5>

            <div class="row">
                <div class="col-md-3 mb-3">
                    {{ form_label(form.dataInicioPrevista) }}
                    {{ form_widget(form.dataInicioPrevista, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.dataInicioPrevista) }}
                </div>

                <div class="col-md-3 mb-3">
                    {{ form_label(form.dataFimPrevista) }}
                    {{ form_widget(form.dataFimPrevista, { attr: { class: 'form-control' } }) }}
                    {{ form_errors(form.dataFimPrevista) }}
                </div>
            </div>

            {# ================= AÇÕES ================= #}
            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="{{ path('app_projeto_index') }}" class="btn btn-outline-secondary">
                    Voltar
                </a>

                <button class="btn btn-primary">
                    Salvar projeto
                </button>
            </div>

             {{ form_end(form) }}

        </div>
    </div>

</div>
{% endblock %}
