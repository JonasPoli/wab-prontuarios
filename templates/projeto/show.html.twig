{% extends 'base.html.twig' %}

{% block title %}Projeto{% endblock %}

{% block body %}
    <h1>Projeto</h1>

    <table>
        <tbody>
            <tr>
                <th>ID</th>
                <td>{{ projeto.id }}</td>
            </tr>
            <tr>
                <th>Título</th>
                <td>{{ projeto.titulo }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ projeto.status }}</td>
            </tr>
            <tr>
                <th>Descrição</th>
                <td>{{ projeto.descricaoDetalhada }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_projeto_edit', { id: projeto.id }) }}">Editar projeto</a>

    

    <h2>Registros históricos</h2>

    <a href="{{ path('app_registro_historico_new', { id: projeto.id }) }}">
        Novo registro histórico
    </a>

    

    <ul>
        {% for registro in projeto.registrosHistorico %}
            <li>
                <strong>{{ registro.dataRegistro|date('d/m/Y H:i') }}</strong> –
                {{ registro.titulo }}

                {% if registro.visivelParaCliente %}
                    (Visível para cliente)
                {% endif %}
            </li>
        {% else %}
            <li>Nenhum registro histórico cadastrado.</li>
        {% endfor %}
    </ul>

    <a href="{{ path('app_projeto_index') }}">Voltar para a lista</a>
{% endblock %}
