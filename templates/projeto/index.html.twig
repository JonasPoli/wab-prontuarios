{% extends 'base.html.twig' %}

{% block title %}Projetos{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ================= CABEÇALHO ================= #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Projetos</h1>

        <a href="{{ path('app_projeto_new') }}" class="btn btn-primary">
            + Novo projeto
        </a>
    </div>

    {# ================= LISTAGEM ================= #}
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Título</th>
                        <th>Cliente</th>
                        <th>Status</th>
                        <th>Início previsto</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                {% for projeto in projetos %}
                    <tr>
                        <td>
                            <strong>{{ projeto.titulo }}</strong>
                        </td>

                        <td>
                            {{ projeto.cliente.nome }}
                        </td>

                        <td>
                            {% if projeto.status == 'planejado' %}
                                <span class="badge bg-secondary">Planejado</span>
                            {% elseif projeto.status == 'em_andamento' %}
                                <span class="badge bg-primary">Em andamento</span>
                            {% elseif projeto.status == 'concluido' %}
                                <span class="badge bg-success">Concluído</span>
                            {% elseif projeto.status == 'cancelado' %}
                                <span class="badge bg-danger">Cancelado</span>
                            {% endif %}
                        </td>

                        <td>
                            {{ projeto.dataInicioPrevista
                                ? projeto.dataInicioPrevista|date('d/m/Y')
                                : '—'
                            }}
                        </td>

                        <td class="text-end">
                            <a href="{{ path('app_projeto_show', { id: projeto.id }) }}"
                               class="btn btn-sm btn-outline-primary">
                                Ver
                            </a>

                            <a href="{{ path('app_projeto_edit', { id: projeto.id }) }}"
                               class="btn btn-sm btn-outline-secondary">
                                Editar
                            </a>

                            {% if projeto.status != 'cancelado' %}
                                <form method="post"
      action="{{ path('app_projeto_cancelar', { id: projeto.id }) }}"
      style="display:inline"
      onsubmit="return confirm('Tem certeza que deseja cancelar este projeto?');">

    <button class="btn btn-sm btn-outline-danger">
        Cancelar
    </button>
</form>

                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Nenhum projeto cadastrado
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

        </div>
    </div>

</div>
{% endblock %}
