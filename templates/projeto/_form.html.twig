{{ form_start(form) }}

<h5 class="mb-3">Dados do projeto</h5>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_label(form.codigoInterno) }}
        {{ form_widget(form.codigoInterno, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.codigoInterno) }}
    </div>

    <div class="col-md-8 mb-3">
        {{ form_label(form.titulo) }}
        {{ form_widget(form.titulo, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.titulo) }}
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        {{ form_label(form.cliente) }}
        {{ form_widget(form.cliente, { attr: { class: 'form-select' } }) }}
        {{ form_errors(form.cliente) }}
    </div>

    <div class="col-md-6 mb-3">
        {{ form_label(form.status) }}
        {{ form_widget(form.status, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.status) }}
    </div>
</div>

<hr>

<h5 class="mb-3">Descrição</h5>

<div class="mb-3">
    {{ form_label(form.descricao) }}
    {{ form_widget(form.descricao, {
        attr: { class: 'form-control', rows: 4 }
    }) }}
    {{ form_errors(form.descricao) }}
</div>

<hr>

<h5 class="mb-3">Prazos</h5>

<div class="row">
    <div class="col-md-6 mb-3">
        {{ form_label(form.dataInicioPrevista) }}
        {{ form_widget(form.dataInicioPrevista, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.dataInicioPrevista) }}
    </div>

    <div class="col-md-6 mb-3">
        {{ form_label(form.dataFimPrevista) }}
        {{ form_widget(form.dataFimPrevista, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.dataFimPrevista) }}
    </div>
</div>

<div class="d-flex justify-content-end gap-2 mt-4">
    <a href="{{ path('app_projeto_index') }}" class="btn btn-outline-secondary">
        Voltar
    </a>

    <button class="btn btn-primary">
        Salvar projeto
    </button>
</div>

{{ form_end(form) }}
